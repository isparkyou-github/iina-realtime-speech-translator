{
  "name": "Realtime Speech Translator",
  "version": "1.1.0",
  "identifier": "dev.codex.iina.realtime-speech-translator",
  "author": {
    "name": "Codex"
  },
  "description": "Transcribe the playing audio in near real time, translate it, and render the result as an overlay.",
  "entry": "main.js",
  "preferencesPage": "preferences.html",
  "permissions": [
    "show-osd",
    "video-overlay",
    "network-request",
    "file-system"
  ],
  "allowedDomains": [
    "*"
  ],
  "preferenceDefaults": {
    "enabled": true,
    "apiKey": "",
    "ffmpegPath": "",
    "curlPath": "",
    "transcriptionUrl": "https://api.openai.com/v1/audio/transcriptions",
    "transcriptionModel": "gpt-4o-mini-transcribe",
    "transcriptionPrompt": "",
    "chatUrl": "https://api.openai.com/v1/chat/completions",
    "chatModel": "gpt-4o-mini",
    "targetLanguage": "Simplified Chinese",
    "sourceLanguage": "auto",
    "showTranscript": true,
    "fontSize": 28,
    "bottomOffset": 9,
    "maxWidth": 82,
    "chunkSeconds": 4,
    "pollIntervalMs": 1500,
    "maxCatchupSeconds": 8
  }
}
